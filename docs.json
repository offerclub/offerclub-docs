{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Offerclub Docs",
  "colors": {
    "primary": "#000000",
    "light": "#F9F9F9",
    "dark": "#1A1A1A"
  },
  "fonts": {
    "family": "Outfit"
  },
  "seo": {
    "metatags": {
      "robots": "noindex"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "https://api.offerclub.io/public-swagger-json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://offerclub.io/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "href": "https://offerclub.io/apps",
        "label": "Integrations"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://my.offerclub.io/"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
    "perplexity",
    "assistant"
  ]
  },
  "footer": {
    "socials": {
      "facebook": "https://www.facebook.com/offerclub.io",
      "instagram": "https://www.instagram.com/offerclub.io/",
      "x": "https://x.com/offerclub_io",
      "github": "https://github.com/offerclub"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "icons": {
    "library": "lucide"
  },
  "integrations": {
    "gtm": {
      "tagId": "GTM-5P3N43TH"
    }
  },
  "metadata": {
    "timestamp": false
  },
  "errors": {
    "404": {
      "redirect": true,
      "title": "Oops! Page not found",
      "description": "This page doesn’t exist or was removed. We suggest you go back home."
    }
  },
  "api": {
    "openapi": "https://api.offerclub.io/public-swagger-json"
  },
  "interaction": {
    "drilldown": false
  }
}
